# ZHYC 快速开发平台环境变量示例
# 复制为本地 .env 或按部署平台注入环境变量。不要提交真实密码、Token、私钥或客户数据。

ZHYC_ENV=dev

# 平台服务
ZHYC_PLATFORM_PORT=8081
ZHYC_PLATFORM_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/zhyc-base-v1?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
ZHYC_PLATFORM_DATASOURCE_USERNAME=replace_with_platform_db_user
ZHYC_PLATFORM_DATASOURCE_PASSWORD=replace_with_platform_db_password
ZHYC_PLATFORM_AUTH_JWK_SET_URI=http://127.0.0.1:8090/oauth2/jwks
ZHYC_PLATFORM_AUTH_ISSUER=http://127.0.0.1:8090
ZHYC_PLATFORM_AUTH_TOKEN_URI=http://127.0.0.1:8090/oauth2/token
ZHYC_PLATFORM_AUTH_CLIENT_ID=zhyc-auth-client
ZHYC_PLATFORM_AUTH_CLIENT_SECRET=replace_with_auth_client_secret

# 认证中心
ZHYC_AUTH_PORT=8090
ZHYC_AUTH_CLIENT_ID=zhyc-auth-client
ZHYC_AUTH_CLIENT_SECRET=replace_with_auth_client_secret
ZHYC_AUTH_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
ZHYC_AUTH_LOGIN_SUCCESS_REDIRECT_URI=http://127.0.0.1:5173/login
ZHYC_AUTH_FRONTEND_LOGIN_URI=http://127.0.0.1:5173/login?authRequest=1
ZHYC_AUTH_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:5173/login?loggedOut=1
ZHYC_AUTH_ISSUER=http://127.0.0.1:8090
ZHYC_AUTH_USER_NAME=replace_with_auth_user
ZHYC_AUTH_USER_PASSWORD=replace_with_auth_user_password
ZHYC_AUTH_PLATFORM_TENANT_ID=zhyc-platform
ZHYC_AUTH_PLATFORM_USER_ID=replace_with_platform_user_id
ZHYC_AUTH_PLATFORM_USERNAME=replace_with_platform_username
ZHYC_AUTH_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/zhyc_auth?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
ZHYC_AUTH_DATASOURCE_USERNAME=replace_with_auth_db_user
ZHYC_AUTH_DATASOURCE_PASSWORD=replace_with_auth_db_password
ZHYC_AUTH_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver
ZHYC_AUTH_JWK_PRIVATE_KEY_PEM=replace_with_private_key_pem
ZHYC_AUTH_JWK_PUBLIC_KEY_PEM=replace_with_public_key_pem
ZHYC_AUTH_JWK_KEY_ID=replace_with_key_id

# 开放 API 网关
ZHYC_OPENAPI_PORT=8070
ZHYC_OPENAPI_OAUTH2_INTROSPECTION_URI=http://127.0.0.1:8090/oauth2/introspect
ZHYC_OPENAPI_OAUTH2_CLIENT_ID=replace_with_introspection_client_id
ZHYC_OPENAPI_OAUTH2_CLIENT_SECRET=replace_with_introspection_client_secret

# Redis 与缓存
ZHYC_REDIS_HOST=127.0.0.1
ZHYC_REDIS_PORT=6379
ZHYC_REDIS_PASSWORD=
ZHYC_REDIS_DATABASE=0
ZHYC_REDIS_TIMEOUT=2s
ZHYC_CACHE_ENABLED=true
ZHYC_CACHE_PREFIX=zhyc

# 后台前端
VITE_API_BASE_URL=/api
VITE_AUTH_AUTHORIZATION_ENDPOINT=http://127.0.0.1:8090/oauth2/authorize
VITE_AUTH_CLIENT_ID=zhyc-auth-client
VITE_AUTH_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
VITE_AUTH_SCOPE=openid profile
VITE_AUTH_LOGOUT_ENDPOINT=http://127.0.0.1:8090/logout
VITE_AUTH_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:5173/login?loggedOut=1
VITE_AUTH_LOGIN_ENDPOINT=http://127.0.0.1:8090/login
